# MODE=p010 drives the TWO-SHOT (PHOTO HDR -> P010 buffer, THEN MASTER/Pro), the actual D1 native
# P010/plane-layout + lock contract. (Was MODE=photo — a plain photo that didn't exercise the Master half.)
MODE=p010
AE_LOCK=1
REPEAT_N=2
NOTE="D1 native P010/plane-layout + lock contract (the libapsfixup target): two-shot HDR Photo (P010) + Master/Pro capture"
EXTRA_PROBES="trace_p010_planes trace_arcsoft_io trace_dmabuf_alloc"
