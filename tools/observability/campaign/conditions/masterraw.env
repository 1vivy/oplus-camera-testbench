MODE=masterraw
AE_LOCK=1
REPEAT_N=2
# Duped from p010 + a JPG->RAW switch on the MASTER/Pro shot. Two captures: (1) PHOTO HDR (P010 buffer, same
# as p010), then (2) MASTER/Pro in RAW (DNG) — exercises the Pro RAW output stream + master op_mode. RAW (like
# Pro) is sticky, so the drive switches JPG->RAW feedback-driven and RESETS to JPG after (hygiene, so p010 and
# any later master capture stay JPG). Verify a .dng lands in DCIM/Camera (or /Raw) for the master shot.
NOTE="Master/Pro RAW (DNG) capture — p010 dupe with JPG->RAW switch; Pro RAW output stream + op_mode; self-resets format to JPG"
EXTRA_PROBES="hook_configure_streams trace_p010_planes"
