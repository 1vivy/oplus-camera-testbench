# Condition: RGB-fan high-DR scene, AE/AF locked, single photo, x3 (determinism).
# The canonical #2/#3 HDR-family de-confound condition — replayed deterministically so a Gate-A flip is
# attributable to the scene, not exposure drift. Sourced by run_condition.sh.
MODE=replay                       # drive_cycle replay mode
SESSION=rgbfan-photo-aelock       # campaign/sessions/<SESSION>.actions (the recorded sequence; calls aelock itself)
AE_LOCK=0                         # 0 = the .actions file already locks; set 1 only for non-replay modes
SELINUX=                          # blank=keep current (Enforcing). frida/strace work under Enforcing on this device.
REPEAT_N=3
NOTE="bright white RGB fan, fixed mount, AE/AF locked via long-press; high-DR (bright fans on dark PC interior)"
EXTRA_PROBES=""                   # e.g. "strace perfetto" once those runners are auto-replay-wired
