MODE=photo
AE_LOCK=1
SELINUX=
REPEAT_N=2
NOTE="FULL stock baseline — framework+graph (ab_capture) + provider-side probes + app-side probes + r3-gralloc + r4-oem-transact, captured in one pass. Run via full_baseline.sh (not run_condition.sh, which only co-attaches the provider subset)."
# Provider-side probes are co-attached by run_condition.sh (persistent provider).
# App-side probes are driven by app_probe_capture.sh (fresh app pid + DRIVE_NAVONLY).
# full_baseline.sh routes each probe to the right lane automatically.
EXTRA_PROBES="observe_getmetadata dump_camxsettings probe_aec_hdrdetect hook_configure_streams trace_p010_planes trace_edr_invocation trace_preview_delivery trace_aps_metadata_lifecycle"
# r3/r4 kit toggles consumed by full_baseline.sh (1=run, 0=skip). Best-effort; do not block the core baseline.
RUN_R3=1
RUN_R4=1
