# Condition: full pinch-out to 120x MAX zoom (AI super-zoom) — a genuinely distinct capture path from the
# 1x photo. The driver does a real protocol-B multitouch pinch (sendevent on the touchpanel; `input` can't
# multitouch) to ramp the zoom dial to the 120x clamp, which engages the digital-zoom AI upscale pipeline,
# then asserts PHOTO scope and captures. Provider/server probes capture the zoom op_mode + stream config.
MODE=switch
AE_LOCK=1
SELINUX=                          # blank=keep current (Enforcing)
REPEAT_N=3
NOTE="full pinch-out to 120x max (AI super-zoom) — PHOTO mode single capture at max digital zoom; distinct configure_streams/op_mode + AI upscale path vs 1x"
EXTRA_PROBES="hook_configure_streams probe_get_extension_opmode"
